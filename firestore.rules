rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Solo usuarios autenticados pueden leer/escribir
    match /cuarteles/{cuartelId}/{documento=**} {
      allow read, write: if request.auth != null && 
        request.auth.uid != null &&
        exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.cuartelId == cuartelId &&
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.activo == true;
    }
    
    // Usuarios: solo el propio usuario o administrador pueden leer/escribir
    match /usuarios/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && 
        (request.auth.uid == userId || 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol == 'administrador');
    }
  }
}